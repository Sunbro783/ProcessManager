<Window x:Class="ProcessManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:vm="clr-namespace:ProcessManager.ViewModels"
        xmlns:conv="clr-namespace:ProcessManager.Converters"
        Title="Process Manager"
        Height="820"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        Background="#F2F4F7">

    <Window.Resources>
        <conv:PriorityToBrushConverter x:Key="PriorityBrush"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- ================= Панель управления ================= -->

        <Border Grid.Row="0"
                Background="White"
                Padding="10"
                CornerRadius="6"
                Margin="0 0 0 10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Grid Grid.Column="0" Width="220">

                    <TextBox
        Height="28"
        Padding="5"
        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
        x:Name="SearchBox"/>

                    <TextBlock
        Text="Поиск по имени"
        Margin="8,0,0,0"
        VerticalAlignment="Center"
        Foreground="Gray"
        IsHitTestVisible="False">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>

                </Grid>

                <CheckBox Grid.Column="1"
                          Margin="10 0"
                          VerticalAlignment="Center"
                          Content="Только GUI"
                          IsChecked="{Binding OnlyGUI}"/>

                <CheckBox Grid.Column="2"
                          Margin="10 0"
                          VerticalAlignment="Center"
                          Content="Только системные"
                          IsChecked="{Binding OnlySystem}"/>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="15 0">

                    <TextBlock Text="Интервал:"
                               VerticalAlignment="Center"
                               Margin="0 0 6 0"/>

                    <ComboBox Width="90"
                              Height="26"
                              ItemsSource="{Binding RefreshIntervals}"
                              SelectedItem="{Binding RefreshInterval}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat={}{0} сек}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                    </ComboBox>

                </StackPanel>

                <Button Grid.Column="4"
                        Margin="10 0"
                        Padding="10 4"
                        Content="Завершить процесс"
                        Command="{Binding KillCommand}"/>

                <ComboBox Grid.Column="5"
                          Width="120"
                          Height="26"
                          Margin="10 0"
                          ItemsSource="{Binding PriorityValues}"
                          SelectedItem="{Binding SelectedProcess.Priority}"/>

                <Button Grid.Column="6"
                        HorizontalAlignment="Left"
                        Padding="10 4"
                        Content="Изменить приоритет"
                        Command="{Binding ChangePriorityCommand}"/>

            </Grid>

        </Border>


        <!-- ================= Таблица процессов ================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="6"
                Padding="5">

            <DataGrid ItemsSource="{Binding Processes}"
                      SelectedItem="{Binding SelectedProcess}"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      RowHeight="28"
                      IsReadOnly="True"
                      Margin="5">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="PID"
                                        Binding="{Binding Id}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Имя"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Приоритет"
                                        Binding="{Binding Priority}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Память (MB)"
                                        Binding="{Binding MemoryMB}"
                                        Width="140"/>

                    <DataGridTextColumn Header="CPU Time"
                                        Binding="{Binding CpuTime}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Потоки"
                                        Binding="{Binding ThreadCount}"
                                        Width="90"/>

                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background"
                                Value="{Binding Priority, Converter={StaticResource PriorityBrush}}"/>
                    </Style>
                </DataGrid.RowStyle>

            </DataGrid>

        </Border>


        <!-- ================= Нижняя часть ================= -->

        <Grid Grid.Row="2" Margin="0 10 0 0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- Потоки -->
            <GroupBox Header="Потоки"
                      Grid.Column="0"
                      Margin="5"
                      Background="White">

                <DataGrid ItemsSource="{Binding Threads}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"/>

                        <DataGridTextColumn Header="Приоритет"
                                            Binding="{Binding Priority}"/>

                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding State}"/>

                        <DataGridTextColumn Header="CPU Time"
                                            Binding="{Binding ProcessorTime}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </GroupBox>


            <!-- Дерево -->
            <GroupBox Header="Иерархия процессов"
                      Grid.Column="1"
                      Margin="5"
                      Background="White">

                <TreeView ItemsSource="{Binding ProcessTree}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock>
                                <Run Text="{Binding Process.Name}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Process.Id}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

            </GroupBox>


            <!-- CPU -->
            <GroupBox Header="Загрузка CPU по ядрам"
                      Grid.Column="2"
                      Margin="5"
                      Background="White">

                <lvc:CartesianChart Series="{Binding CpuSeries}"
                                    AxisX="{Binding CpuAxisX}"
                                    AxisY="{Binding CpuAxisY}"
                                    AnimationsSpeed="0:0:0"
                                    Hoverable="True"/>

            </GroupBox>


            <!-- Память -->
            <GroupBox Header="Top-10 по памяти"
                      Grid.Column="3"
                      Margin="5"
                      Background="White">

                <lvc:PieChart Series="{Binding MemorySeries}"
                              AnimationsSpeed="0:0:0"
                              Hoverable="True"/>

            </GroupBox>

        </Grid>

    </Grid>
</Window>